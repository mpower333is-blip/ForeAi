generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  handicap Float?

  rounds Round[]
  clubs  Club[]

  createdAt DateTime @default(now())
}

model Round {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  courseName String
  totalScore Int

  shots Shot[]

  createdAt DateTime @default(now())
}

model Shot {
  id String @id @default(uuid())

  roundId String
  round   Round  @relation(fields: [roundId], references: [id])

  hole Int

  club    String
  yardage Int

  lie       String?
  wind      Int?
  elevation Int?

  result     String
  dispersion String?

  expectedStrokes Float?
  strokesGained   Float?

  createdAt DateTime @default(now())
}

model Club {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  name     String
  avgCarry Int

  dispersion Int?

  createdAt DateTime @default(now())
}
